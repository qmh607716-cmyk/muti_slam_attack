<launch>
    <!--
        ROS bag attack injector for LVI-SAM on KITTI dataset.
        Usage:
          roslaunch slamspoof_icra rosbag_editer_kitti.launch config_file_path:=path/to/config.json

        Set params first via roslaunch, then run the editor node:
          roslaunch slamspoof_icra rosbag_editer_kitti.launch
        Then in another terminal:
          rosrun slamspoof_icra spoofing_editer_lvisam.py
    -->
    <arg name="config_file_path"
         default="$(find slamspoof_icra)/config_lvisam_kitti.json"/>
    <param name="config_file" value="$(arg config_file_path)"/>
     <!-- Launch the Rosbag attack editor node -->
    <node name="rosbag_editer_lvisam" pkg="slamspoof_icra" type="spoofing_editer_lvisam.py" output="screen" cwd="node"/>
</launch>
